# Copy to .env (already in .gitignore) and fill in your values. NEVER commit .env.
# Secrets live here or in the system keyring, never in source code.

# Optional path to your olibuguard config.yaml.
OLIBUGUARD_CONFIG=

# Exchange API credentials.
# For paper trading (sandbox=true in config.json): use Binance Spot Testnet keys.
#   → Get them free at https://testnet.binance.vision/ (GitHub login required).
# For live mode: use real Binance keys — NO withdrawal permission, IP whitelist mandatory.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Freqtrade Telegram integration (optional; disabled by default in user_data/config.json).
FREQTRADE__TELEGRAM__ENABLED=false
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# FreqUI credentials (overrides the placeholders in user_data/config.json).
# The API server is bound to 127.0.0.1 only — never reachable from the network.
# Open http://localhost:8080 after starting the bot to access the dashboard.
FREQTRADE__API_SERVER__USERNAME=olibuguard
FREQTRADE__API_SERVER__PASSWORD=
FREQTRADE__API_SERVER__JWT_SECRET_KEY=

# olibuguard Telegram alerts (optional; startup notice, circuit breaker trips, equity drift).
# Get the token from @BotFather; get the chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AWS credentials for the Bedrock AI advisor (Phase 3, optional).
# Required only when ai.enabled = true and ai.provider = "bedrock" in config.yaml.
#
# Preferred (role-based, no static keys):
#   Set  ai.profile: a9e  in config.yaml — boto3 assumes the role from ~/.aws/config.
#   No env vars needed; leave the lines below blank or omit them entirely.
#
# Alternative (static keys, last resort — avoid if you can use a role):
#   The IAM user needs bedrock:InvokeModel on the configured model ARN only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
