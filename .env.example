# Copia a .env (ya está en .gitignore) y rellena. NUNCA subas .env al repo.
# Los secretos viven aquí o en el keyring del sistema, jamás en el código.

# Ruta opcional a tu config.yaml de olibuguard.
OLIBUGUARD_CONFIG=

# Secretos del exchange para Freqtrade en modo live (en paper/backtest no hacen falta).
# Freqtrade lee estas variables y sobreescribe user_data/config.json.
# La API key del exchange debe crearse SIN permiso de retiro y con IP whitelist.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Alertas Telegram (opcional; enabled=false por defecto en user_data/config.json).
FREQTRADE__TELEGRAM__ENABLED=false
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=
