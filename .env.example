# Copy to .env (already in .gitignore) and fill in your values. NEVER commit .env.
# Secrets live here or in the system keyring, never in source code.

# Optional path to your olibuguard config.yaml.
OLIBUGUARD_CONFIG=

# Exchange secrets for Freqtrade in live mode (not needed for paper/backtest).
# Freqtrade reads these variables and overrides user_data/config.json.
# The exchange API key must be created WITHOUT withdrawal permission and with an IP whitelist.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Freqtrade Telegram integration (optional; disabled by default in user_data/config.json).
FREQTRADE__TELEGRAM__ENABLED=false
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# olibuguard Telegram alerts (optional; startup notice, circuit breaker trips, equity drift).
# Get the token from @BotFather; get the chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
