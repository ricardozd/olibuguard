# Bybit DEMO TRADING credentials — copy to .env.bybit and fill in.
# Generate these in a Bybit account with DEMO TRADING enabled:
#   1. Log in at bybit.com (create an account if needed).
#   2. Top-right profile menu → switch to "Demo Trading" (or visit the Demo Trading area).
#   3. Inside Demo Trading → API → create a new API key (System-generated).
#      Permissions: enable "Trade" / "Contract — Orders & Positions".
#   4. Paste the key/secret below.
# These keys ONLY work against api-demo.bybit.com — they cannot touch real funds.
FREQTRADE__EXCHANGE__KEY=your_bybit_demo_key_here
FREQTRADE__EXCHANGE__SECRET=your_bybit_demo_secret_here
